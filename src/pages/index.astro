---
/**
 * Recipe: Red Charge
 * Category: Roofing
 * Reference: One Nation Exteriors (onenationexteriors.com)
 *
 * Bold navy + crimson red palette. Plus Jakarta Sans headings, Inter body.
 * Designed for high-conversion roofing companies with strong local presence.
 * Self-contained — NO external component imports.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import StickyMinimal from "../../components/nav/StickyMinimal.astro";
import MultiColumn from "../../components/footer/MultiColumn.astro";
import { siteConfig } from "../lib/site-config";
import { getSeoForPage } from "../lib/seo";

const seo = getSeoForPage("homepage");
const biz = siteConfig.business;
const content = siteConfig.content;
const homepage = content.homepage;
const services = content.services;
const serviceAreas = content.serviceAreas;
const reviews = content.reviews;
const info = content.companyInfo;
const images = siteConfig.images;
const heroR = (images as any).heroResponsive;
const servicesR = (images as any).servicesResponsive || {};

const displayServices = services.slice(0, 6);
const displayAreas = serviceAreas.slice(0, 8);
const displayReviews = reviews.slice(0, 6);
const galleryImages = images.gallery?.length ? images.gallery.slice(0, 6) : Object.values(images.services || {}).slice(0, 3);
const firstFaq = services[0]?.faq || [];

// Slug-to-display-name mapping

const ACRONYMS = new Set(["hvac", "ac", "bbq", "rv", "atv", "suv"]);
function nicheDisplayName(input: string): string {
  return input.split(/[\s-]+/).map(word => {
    if (ACRONYMS.has(word.toLowerCase())) return word.toUpperCase();
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(" ");
}
const categoryDisplay = nicheDisplayName(biz.category);

// Niche-aware language mappings
const medicalNiches = new Set(["dentist", "chiropractor", "physical-therapy", "optometrist", "veterinarian"]);
const autoNiches = new Set(["auto-repair", "auto-body", "auto-detailing", "towing", "tire-shop"]);
const isMedical = medicalNiches.has(biz.category);
const isAuto = autoNiches.has(biz.category);
const ctaText = isMedical ? "Book an Appointment" : "Get a Free Estimate";
const ctaAction = isMedical ? "Schedule a Visit" : isAuto ? "Get a Quote" : "Request an Estimate";

// Niche display name → professional adjective form
const NICHE_ADJECTIVES: Record<string, string> = {
  "dentist": "Dental Care",
  "chiropractor": "Chiropractic Care",
  "optometrist": "Optometry",
  "veterinarian": "Veterinary Care",
  "physical-therapy": "Physical Therapy",
  "auto-repair": "Auto Repair",
  "auto-body": "Auto Body Repair",
  "auto-detailing": "Auto Detailing",
  "towing": "Towing",
  "tire-shop": "Tire Service",
  "electrical": "Electrical Services",
  "solar": "Solar Installation",
  "smart-home": "Smart Home Solutions",
  "handyman": "Handyman Services",
  "general-contractor": "General Contracting",
  "kitchen-remodel": "Kitchen Remodeling",
  "bath-remodel": "Bathroom Remodeling",
  "garage-door": "Garage Door Service",
};
const categoryAdjective = NICHE_ADJECTIVES[biz.category] || categoryDisplay;

// Article helper: "a" vs "an"
const categoryArticle = /^[aeiou]/i.test(categoryDisplay) ? "an" : "a";



const phone = biz.phone || "";
const phoneFmt = phone.replace(/(\d{3})(\d{3})(\d{4})/, "($1) $2-$3");
const email = biz.email || "";
const city = biz.city || "Your City";
const state = biz.state || "";
const yearFounded = biz.yearFounded || 2010;
const yearsExp = new Date().getFullYear() - yearFounded;
const heroImg = images.hero;
const logoImg = images.logo;

const residentialServices = services.filter(s => {
  const name = (s.name || s.title || "").toLowerCase();
  return false; // All services go to additional grid
}).slice(0, 4);

const commercialServices = services.filter(s => {
  const name = (s.name || s.title || "").toLowerCase();
  return name.includes("commercial") || name.includes("multi") || name.includes("flat");
}).slice(0, 3);

const additionalServices = services.filter(s => {
  const name = (s.name || s.title || "").toLowerCase();
  return !name.includes("residential") && !name.includes("commercial") && !name.includes("multi");
}).slice(0, 4);

const reviewerColors = ["#1F3A56", "#DC143C", "#475569", "#1F3A56", "#DC143C", "#475569"];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>

  <!-- ═══════════════════════════════════════════ TOP BAR ═══════════════════════════════════════════ -->
  <StickyMinimal slot="nav" />

  <!-- ═══════════════════════════════════════════ NAV ═══════════════════════════════════════════ -->

  <!-- ═══════════════════════════════════════════ HERO ═══════════════════════════════════════════ -->
  <section class="rc-hero">
    {heroImg && <img src={heroImg} alt={`${biz.name} — professional ${categoryAdjective.toLowerCase()} services in ${city}`} class="rc-hero__bg" srcset={heroR?.srcset || ""} sizes="100vw" loading="eager" fetchpriority="high" />}
    <div class="rc-hero__overlay"></div>
    <div class="rc-hero__inner rc-container">
      <div class="rc-hero__content">
        <span class="rc-hero__badge">{`Trusted ${city} ${categoryAdjective} Experts`}</span>
        <h1 class="rc-hero__title">{homepage.heroHeadline || `Leading the Way in ${categoryDisplay}`}</h1>
        <p class="rc-hero__subtitle">{homepage?.heroSubline || `Trusted across ${city} for quality ${categoryDisplay.toLowerCase()} services. We deliver results backed by experience and dedication to excellence.`}</p>

        <div class="rc-hero__trust">
          <span class="rc-hero__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Family Owned &amp; Operated
          </span>
          <span class="rc-hero__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Industry Certified
          </span>
          <span class="rc-hero__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {yearsExp}+ Years of Experience
          </span>
          <span class="rc-hero__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            5.0 Rating
          </span>
        </div>

        <div class="rc-hero__reviews">
          <div class="rc-hero__review-badges">
            <span class="rc-hero__review-dot rc-hero__review-dot--google">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              5.0
            </span>
            <span class="rc-hero__review-dot rc-hero__review-dot--fb">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              5.0
            </span>
            <span class="rc-hero__review-dot rc-hero__review-dot--bbb">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              A+
            </span>
          </div>
          <span class="rc-hero__review-label">Verified Reviews</span>
        </div>
      </div>

      <div class="rc-hero__form-wrap">
        <div class="rc-hero__form-card">
          <h2 class="rc-hero__form-heading">{ctaText}</h2>
          <form class="rc-hero__form" action="/contact/" method="GET">
            <input type="text" name="name" placeholder="Full Name" required class="rc-hero__input" />
            <input type="email" name="email" placeholder="Email Address" required class="rc-hero__input" />
            <input type="tel" name="phone" placeholder="Phone Number" class="rc-hero__input" />
            <select name="service" aria-label="Select a Service" class="rc-hero__input rc-hero__select">
              <option value="">Select a Service</option>
              {services.map(s => (
                <option value={s.slug}>{s.name || s.title}</option>
              ))}
            </select>
            <input type="text" name="address" placeholder="Your City / Zip Code" class="rc-hero__input" />
            <label class="form-consent" style="display:flex;gap:0.5rem;align-items:flex-start;font-size:0.75rem;color:var(--color-text-light,#666);line-height:1.5;margin:0.75rem 0;"><input type="checkbox" name="consent" required style="margin-top:0.2rem;flex-shrink:0" /><span>By submitting, I consent to receive calls/texts from {biz.name} at the number provided. Msg & data rates may apply. Reply STOP to opt out. <a href="/privacy/" style="color:var(--color-primary);text-decoration:underline">Privacy Policy</a> & <a href="/terms/" style="color:var(--color-primary);text-decoration:underline">Terms</a>.</span></label>
            <button type="submit" class="rc-btn rc-btn--primary rc-hero__submit">Get Started &rarr;</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ TESTIMONIALS ═══════════════════════════════════════════ -->
  <section class="rc-testimonials rc-section">
    <div class="rc-container">
      <div class="rc-testimonials__header">
        <h2 class="rc-section__title">What Your Neighbors Have to Say</h2>
        <a href="/reviews/" class="rc-link--arrow">Read More Reviews &rarr;</a>
      </div>
      <div class="rc-testimonials__grid">
        {displayReviews.slice(0, 4).map((review, idx) => {
          const name = review.author || review.name || "Happy Customer";
          const initial = name.charAt(0).toUpperCase();
          const color = reviewerColors[idx % reviewerColors.length];
          return (
            <div class="rc-testimonial-card">
              <div class="rc-testimonial-card__top">
                <span class="rc-testimonial-card__avatar" style={`background-color: ${color}`}>
                  {initial}
                </span>
                <div class="rc-testimonial-card__meta">
                  <span class="rc-testimonial-card__name">{name}</span>
                  <span class="rc-testimonial-card__stars">
                    {Array.from({ length: 5 }).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#FFD700"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    ))}
                  </span>
                </div>
              </div>
              <p class="rc-testimonial-card__text">{review.text || review.content || review.body}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ SERVICES ═══════════════════════════════════════════ -->
  <section class="rc-services rc-section rc-section--alt">
    <div class="rc-container">
      <div class="rc-services__header">
        <h2 class="rc-section__title">Services Offered</h2>
        <a href="/services/" class="rc-link--arrow">See All Services &rarr;</a>
      </div>

      <div class="rc-services__main-grid">
        <!-- Residential Card -->
        <div class="rc-services__card rc-services__card--main">
          <h3 class="rc-services__card-title">{services[0]?.name || `${categoryDisplay} Services`}</h3>
          <ul class="rc-services__card-list">
            {residentialServices.length > 0 ? (
              residentialServices.map(s => (
                <li><a href={`/services/${s.slug}/`}>{s.name || s.title}</a></li>
              ))
            ) : (
              <>
                {services.slice(0, 3).map(s => <li>{s.name}</li>)}
              </>
            )}
          </ul>
          <a href="/services/" class="rc-link--arrow rc-services__card-link">Learn More &rarr;</a>
        </div>

        <!-- Commercial Card -->
        <div class="rc-services__card rc-services__card--main">
          <h3 class="rc-services__card-title">{services[1]?.name || `Commercial ${categoryDisplay}`}</h3>
          <ul class="rc-services__card-list">
            {commercialServices.length > 0 ? (
              commercialServices.map(s => (
                <li><a href={`/services/${s.slug}/`}>{s.name || s.title}</a></li>
              ))
            ) : (
              <>
                {services.slice(3, 6).map(s => <li>{s.name}</li>)}
              </>
            )}
          </ul>
          <a href="/services/" class="rc-link--arrow rc-services__card-link">Learn More &rarr;</a>
        </div>
      </div>

      <!-- Additional Services -->
      <div class="rc-services__extra">
        <h3 class="rc-services__extra-title">{`Additional ${categoryDisplay} Services`}</h3>
        <div class="rc-services__extra-grid">
          {additionalServices.length > 0 ? (
            additionalServices.map(s => {
              const sImg = images.services?.[s.slug];
              return (
                <a href={`/services/${s.slug}/`} class="rc-services__extra-item">
                  {sImg && <img src={sImg} alt={s.name || s.title} class="rc-services__extra-img" loading="lazy" width="280" height="180" />}
                  {!sImg && heroImg && <img src={heroImg} alt={s.name || s.title} class="rc-services__extra-img" loading="lazy" width="280" height="180" />}
                  <span class="rc-services__extra-name">{s.name || s.title}</span>
                </a>
              );
            })
          ) : (
            displayServices.slice(0, 4).map(s => {
              const sImg = images.services?.[s.slug];
              return (
                <a href={`/services/${s.slug}/`} class="rc-services__extra-item">
                  {sImg && <img src={sImg} alt={s.name || s.title} class="rc-services__extra-img" loading="lazy" width="280" height="180" />}
                  {!sImg && heroImg && <img src={heroImg} alt={s.name || s.title} class="rc-services__extra-img" loading="lazy" width="280" height="180" />}
                  <span class="rc-services__extra-name">{s.name || s.title}</span>
                </a>
              );
            })
          )}
        </div>
      </div>

      <div class="rc-services__callout">
        <div class="rc-services__callout-inner">
          <div class="rc-services__callout-text">
            <h3 class="rc-services__callout-title">{`${biz.name} — Certified Professionals`}</h3>
            <p class="rc-services__callout-desc">{`Our team brings certified expertise and years of experience to every ${categoryDisplay.toLowerCase()} project. We stand behind our work with comprehensive warranties and a commitment to quality.`}</p>
          </div>
          <a href="/about/" class="rc-btn rc-btn--outline">More About Us &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ PROCESS ═══════════════════════════════════════════ -->
  <section class="rc-process rc-section">
    <div class="rc-container">
      <h2 class="rc-section__title rc-section__title--center">The {biz.name} Way</h2>
      <p class="rc-section__subtitle">Our proven process ensures every project is completed with precision, transparency, and care.</p>

      <div class="rc-process__steps">
        <div class="rc-process__line"></div>

        <div class="rc-process__step">
          <div class="rc-process__number">1</div>
          <div class="rc-process__content">
            <h3 class="rc-process__step-title">Consultation</h3>
            <p class="rc-process__step-desc">{`We start with a thorough, no-obligation assessment. Our certified team evaluates your needs and provides a detailed report with recommendations.`}</p>
          </div>
        </div>

        <div class="rc-process__step">
          <div class="rc-process__number">2</div>
          <div class="rc-process__content">
            <h3 class="rc-process__step-title">Plan & Prepare</h3>
            <p class="rc-process__step-desc">{`We work with you to determine the best approach for your specific ${categoryDisplay.toLowerCase()} needs. Our experts ensure the right plan for quality results.`}</p>
          </div>
        </div>

        <div class="rc-process__step">
          <div class="rc-process__number">3</div>
          <div class="rc-process__content">
            <h3 class="rc-process__step-title">Get It Done</h3>
            <p class="rc-process__step-desc">{isMedical ? "Our skilled team delivers your care with precision and attention to detail. We keep you informed and comfortable every step of the way." : "Our skilled team gets to work with precision and efficiency. We maintain a clean, organized environment and keep you informed every step of the way."}</p>
          </div>
        </div>

        <div class="rc-process__step">
          <div class="rc-process__number">4</div>
          <div class="rc-process__content">
            <h3 class="rc-process__step-title">Quality Check</h3>
            <p class="rc-process__step-desc">{isMedical ? "We follow up to ensure your complete satisfaction and optimal results." : "Before we consider any job complete, our team performs a comprehensive quality review. We verify every detail meets our exacting standards."}</p>
          </div>
        </div>

        <div class="rc-process__step">
          <div class="rc-process__number">5</div>
          <div class="rc-process__content">
            <h3 class="rc-process__step-title">Wrap Up</h3>
            <p class="rc-process__step-desc">Transparent pricing with no surprises. You only pay when you're 100% satisfied with the work. We offer flexible options to make the process seamless.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ SERVICE AREA ═══════════════════════════════════════════ -->
  <section class="rc-area rc-section rc-section--alt">
    <div class="rc-container">
      <h2 class="rc-section__title rc-section__title--center">Proudly Serving {city} &amp; Beyond</h2>
      <p class="rc-section__subtitle">{`As a locally owned and operated company, we're proud to serve customers throughout ${city}${state ? `, ${state}` : ""} and the surrounding communities. Our team brings local expertise and dedication to every project.`}</p>

      <div class="rc-area__grid">
        {displayAreas.map(area => (
          <a href={`/service-areas/${area.slug}/`} class="rc-area__tag">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {area.name || area.city}
          </a>
        ))}
      </div>

      <div class="rc-area__cta">
        <a href="/contact/" class="rc-btn rc-btn--primary">Let's Get Started &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FAQ ═══════════════════════════════════════════ -->
  <section class="rc-faq rc-section">
    <div class="rc-container rc-faq__container">
      <h2 class="rc-section__title rc-section__title--center">Frequently Asked Questions</h2>
      <p class="rc-section__subtitle">Get answers to the most common questions {`about our ${categoryDisplay.toLowerCase()} services.`}</p>

      <div class="rc-faq__list">
        {firstFaq.length > 0 ? (
          firstFaq.slice(0, 6).map((item, idx) => (
            <details class="rc-faq__item" open={idx === 0}>
              <summary class="rc-faq__question">
                {item.question || item.q}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{item.answer || item.a}</p>
              </div>
            </details>
          ))
        ) : (
          <>
            <details class="rc-faq__item" open>
              <summary class="rc-faq__question">
{firstFaq[0]?.question || `How long does a typical project take?`}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{firstFaq[0]?.answer || `Project timelines vary based on scope and complexity. Contact us for a detailed estimate.`}</p>
              </div>
            </details>
            <details class="rc-faq__item">
              <summary class="rc-faq__question">
                {firstFaq[1]?.question || `What sets your company apart?`}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{firstFaq[1]?.answer || `Our commitment to quality, transparent pricing, and customer satisfaction sets us apart.`}</p>
              </div>
            </details>
            <details class="rc-faq__item">
              <summary class="rc-faq__question">
                {firstFaq[2]?.question || `Do you offer free estimates?`}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{firstFaq[2]?.answer || `Yes, we offer free, no-obligation estimates for all our services.`}</p>
              </div>
            </details>
            <details class="rc-faq__item">
              <summary class="rc-faq__question">
                Do you offer financing options?
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{firstFaq[3]?.answer || `Yes, we offer flexible options to fit your budget. Contact us for details.`}</p>
              </div>
            </details>
            <details class="rc-faq__item">
              <summary class="rc-faq__question">
                What warranty do you provide on your work?
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="rc-faq__chevron"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="rc-faq__answer">
                <p>{firstFaq[4]?.answer || `We stand behind our work with comprehensive warranties on all services.`}</p>
              </div>
            </details>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FOOTER CTA ═══════════════════════════════════════════ -->
  <section class="rc-footer-cta">
    <div class="rc-container rc-footer-cta__inner">
      <h2 class="rc-footer-cta__title">Built on {city} Values</h2>
      <p class="rc-footer-cta__text">{homepage.ctaSubline || `Ready to work with a ${categoryDisplay.toLowerCase()} team that treats you like family? Let's get started today.`}</p>
      <a href="/contact/" class="rc-btn rc-btn--primary rc-btn--lg">Let's Begin &rarr;</a>
    </div>
  </section>

