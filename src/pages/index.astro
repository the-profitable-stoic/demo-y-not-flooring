<!-- ═══════════════════════════════════════════ MOBILE MENU JS ═══════════════════════════════════════════ -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("rc-menu-btn");
    const menu = document.getElementById("rc-menu");
    const nav = document.getElementById("rc-nav");

    if (btn && menu) {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!expanded));
        menu.classList.toggle("rc-nav__links--open");
        btn.classList.toggle("rc-nav__toggle--active");
      });
    }

    // Dropdown hover + click for mobile
    document.querySelectorAll(".rc-nav__dropdown").forEach((dd) => {
      const trigger = dd.querySelector(".rc-nav__dropdown-trigger");
      if (trigger) {
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          const isOpen = dd.classList.contains("rc-nav__dropdown--open");
          document.querySelectorAll(".rc-nav__dropdown--open").forEach((d) => d.classList.remove("rc-nav__dropdown--open"));
          if (!isOpen) dd.classList.add("rc-nav__dropdown--open");
        });
      }
    });

    // Close dropdowns on outside click
    document.addEventListener("click", (e) => {
      if (!e.target.closest(".rc-nav__dropdown")) {
        document.querySelectorAll(".rc-nav__dropdown--open").forEach((d) => d.classList.remove("rc-nav__dropdown--open"));
      }
    });

    // Sticky nav
    let lastScroll = 0;
    window.addEventListener("scroll", () => {
      const curr = window.scrollY;
      if (nav) {
        if (curr > 100) {
          nav.classList.add("rc-nav--scrolled");
        } else {
          nav.classList.remove("rc-nav--scrolled");
        }
      }
      lastScroll = curr;
    }, { passive: true });
  });
</script>

